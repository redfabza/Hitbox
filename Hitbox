-- =========================
-- RESET
-- =========================
local function resetHitboxes()
    for player, data in pairs(originalSizes) do
        if player and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            local head = player.Character:FindFirstChild("Head")
            if hrp and data.hrpSize then
                hrp.Size = data.hrpSize
                hrp.Transparency = 1
                hrp.CanCollide = true
            end
            if head and data.headSize then
                head.Size = data.headSize
                head.Transparency = 0
                head.CanCollide = true
            end
        end
    end
    table.clear(originalSizes)
end

closeBtn.MouseButton1Click:Connect(function()
    isEnabled = false
    task.wait(0.1)
    resetHitboxes()
    screenGui:Destroy()
end)

Players.PlayerRemoving:Connect(function(player)
    originalSizes[player] = nil
end)

-- =========================
-- HITBOX LOOP
-- =========================
task.spawn(function()
    while screenGui and screenGui.Parent do
        if isEnabled then
            local sizeVec = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    local head = player.Character:FindFirstChild("Head")
                    if hrp then
                        if not originalSizes[player] then
                            originalSizes[player] = {
                                hrpSize = hrp.Size,
                                headSize = head and head.Size or nil
                            }
                        end
                        hrp.Size = sizeVec
                        hrp.Transparency = 0.8
                        hrp.CanCollide = true
                        if head then
                            head.Size = sizeVec
                            head.Transparency = 0.8
                            head.CanCollide = true
                        end
                    end
                end
            end
        else
            if next(originalSizes) ~= nil then
                resetHitboxes()
            end
        end
        task.wait(0.08)
    end
end)

